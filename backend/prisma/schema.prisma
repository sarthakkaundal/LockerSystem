generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  ADMIN
}

enum LockerStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

enum BookingStatus {
  ACTIVE
  COMPLETED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  profilePhoto String?   @db.Text
  passwordHash String
  role         Role      @default(STUDENT)
  studentId    String?
  bookings     Booking[]
}

model Locker {
  id       String       @id @default(cuid())
  code     String       @unique
  location String
  status   LockerStatus @default(AVAILABLE)
  bookings Booking[]
}

model Booking {
  id          String        @id @default(cuid())
  userId      String
  lockerId    String
  startsAt    DateTime
  endsAt      DateTime
  status      BookingStatus @default(ACTIVE)
  otpCode     String
  accessToken String        @unique
  note        String?       @db.Text
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  locker      Locker        @relation(fields: [lockerId], references: [id], onDelete: Cascade)
}

model BookingLog {
  id         String   @id @default(cuid())
  bookingId  String?
  lockerCode String
  actorEmail String?
  action     String
  details    String?  @db.Text
  createdAt  DateTime @default(now())
}

PORT=4000
JWT_SECRET=change-me-to-a-strong-random-secret
FRONTEND_URL=http://localhost:5173

# Neon PostgreSQL — get these from https://console.neon.tech
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
# Direct connection (used by Prisma for migrations/db push)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&connect_timeout=15"
